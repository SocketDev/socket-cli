{
  "extends": "../../.config/fleet/tsconfig.base.json",
  "compilerOptions": {
    "declarationMap": false,
    "jsx": "react-jsx",
    "module": "nodenext",
    "noEmit": true,
    "rewriteRelativeImportExtensions": true,
    "sourceMap": false
  },
  "include": [
    "src/**/*.mts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "test/helpers/**/*.mts"
  ],
  "exclude": [
    ".cache/**",
    ".claude/**",
    "build/**",
    "binaries/**",
    "dist/**",
    "external/**",
    "node_modules/**",
    "pkg-binaries/**",
    "src/**/*.test.mts",
    "test/helpers/**/*.test.mts"
  ]
}
