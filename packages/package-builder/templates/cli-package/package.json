{
  "name": "@socketsecurity/cli",
  "version": "3.0.0-pre.0",
  "private": true,
  "description": "Socket CLI for Socket.dev security analysis",
  "keywords": [
    "cli",
    "security",
    "socket",
    "supply-chain",
    "vulnerability"
  ],
  "homepage": "https://github.com/SocketDev/socket-cli",
  "license": "MIT",
  "author": {
    "name": "Socket Inc",
    "email": "eng@socket.dev",
    "url": "https://socket.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SocketDev/socket-cli.git",
    "directory": "packages/cli"
  },
  "bin": {
    "socket": "bin/cli.js",
    "socket-npm": "bin/npm-cli.js",
    "socket-npx": "bin/npx-cli.js",
    "socket-pnpm": "bin/pnpm-cli.js",
    "socket-yarn": "bin/yarn-cli.js"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "bin/**",
    "data/**",
    "dist/**",
    "!dist/cli.js",
    "logo-dark.png",
    "logo-light.png"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node scripts/build.mts",
    "clean:dist": "del-cli 'dist'",
    "test": "vitest run",
    "verify": "node scripts/verify-package.mts"
  },
  "devDependencies": {
    "build-infra": "workspace:*",
    "rolldown": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
